# Copy to `.env` in the project root (same folder as README).

# --- Optional LLM triage (classification only; tools stay deterministic) ---
SHOPWAVE_USE_LLM_TRIAGE=1

# Ollama (Llama / etc.) — preferred when set
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Or OpenAI-compatible API (used if OLLAMA_BASE_URL is empty)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Simulated flaky tools (timeouts / malformed KB once per process)
AGENT_SIMULATE_FAULTS=0
